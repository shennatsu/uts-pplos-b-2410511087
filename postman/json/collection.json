        {
          "name": "Login Mahasiswa",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('access_token', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refresh_token', json.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{gateway_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@test.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login - Password Salah (401)",
          "request": {
